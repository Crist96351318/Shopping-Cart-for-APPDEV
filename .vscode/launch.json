{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "Launch Chrome/Brave",
            "url": "http://localhost/appdev/Shopping-Cart-for-APPDEV/frontend/${fileBasename}",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMaps": true,
            "runtimeExecutable": "/usr/bin/brave"
        },
        {
            "type": "pwa-msedge",
            "request": "launch",
            "name": "Launch Edge (Windows Fallback)",
            "url": "http://localhost/appdev/Shopping-Cart-for-APPDEV/frontend/${fileBasename}",
            "webRoot": "${workspaceFolder}/frontend",
            "sourceMaps": true
        }
    ]
}